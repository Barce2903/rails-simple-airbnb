<div id="form-container" class="container mx-auto mt-4 p-3 bg-light">
  <h1>Edit flat</h1>
  <%= simple_form_for(@flat) do |f| %>
    <div class="form-inputs">
      <%= f.input :name %>
      <%= f.input :address %>
      <%= f.input :description %>
      <%= f.input :price_per_night %>
      <%= f.input :number_of_guests %>
    </div>
    <div class="form-actions">
      <%= f.submit %>
    </div>
  <% end %>
</div>
