<div class="header-image" style="background-image: url('<%= @flat.url %>')"></div>
<div id="show-container" class="container">
  <div class="row">
    <div class="col-8">
      <div class="p-3 mb-3 border rounded bg-light">
        <h1><%= @flat.name %></h1>
        <p><%= @flat.address %></p>
      </div>
      <div class="p-3 mb-3 border rounded bg-light">
        <h2>A bit more about this flat...</h2>
        <p><%= @flat.description %></p>
      </div>
    </div>
    <div class="col-4">
      <div class="p-3 mb-3 border rounded bg-light">
        <h4>Book this place!</h4>
        <form action="">
          <div class="input-group mb-2">
            <div class="input-group-prepend">
              <span class="input-group-text">From:</span>
            </div>
            <input type="date" class="form-control" id="basic-url" aria-describedby="basic-addon3">
          </div>
          <div class="input-group mb-2">
            <div class="input-group-prepend">
              <span class="input-group-text">To:</span>
            </div>
            <input type="date" class="form-control" id="basic-url" aria-describedby="basic-addon3">
          </div>
          <input type="submit" value="Book" class="btn btn-success mt-2" style="width: 100%">
        </form>
      </div>
      <div class="p-3 mb-3 border rounded bg-light">
        <h3>Details</h3>
        <p><%= @flat.number_of_guests %> people  <%= @flat.price_per_night %>€</p>
      </div>
      <div class="p-3 mb-3 border rounded bg-light d-flex justify-content-between align-items-center">
        <p class="m-0">Share</p>
        <div>
          <i class="fa-brands fa-square-facebook" style="color: #000000;"></i>
          <i class="fa-brands fa-square-twitter" style="color: #000000;"></i>
          <i class="fa-brands fa-square-pinterest" style="color: #000000;"></i>
        </div>
      </div>
    </div>
  </div>
</div>
